# ===== APPLICATION =====
# Nom de l'application
APP_NAME=fridaocr

# Version de l'application
APP_VERSION=1.0.0

# ===== PORTS =====
# Port du backend Spring Boot
BACKEND_PORT=8080

# Port du frontend Angular
FRONTEND_PORT=4200

# Port de la base de données PostgreSQL
DATABASE_PORT=5432

# ===== DATABASE (PostgreSQL) =====
# Type de base de données
DB_VENDOR=postgresql

# Hôte de la base de données (utiliser 'postgres' en Docker)
DB_HOST=postgres

# Port PostgreSQL
DB_PORT=5432

# Nom de la base de données
DB_NAME=fridaaidb

# Utilisateur PostgreSQL
DB_USER=postgres

# Mot de passe PostgreSQL (À CHANGER EN PRODUCTION!)
DB_PASSWORD=your_secure_password_here

# ===== SPRING BOOT =====
# Profile actif (docker, development, production)
SPRING_PROFILES_ACTIVE=docker

# DDL auto: validate, update, create, create-drop
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Afficher les requêtes SQL (false en production)
SPRING_JPA_SHOW_SQL=false

# ===== CORS & SECURITY =====
# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Taille maximale des fichiers en octets (défaut: 10MB = 10485760)
FILE_UPLOAD_MAX_SIZE=10485760

# ===== DOCKER =====
# Nom du projet Docker Compose
COMPOSE_PROJECT_NAME=frida-ai

# ===== OPTIONNEL: Cloud Services =====
# Google Cloud Document AI (si utilisé)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# DOCUMENT_AI_PROJECT_ID=your_project_id
# DOCUMENT_AI_LOCATION=us

# ===== OPTIONNEL: Logging =====
# Niveau de log (INFO, DEBUG, WARN, ERROR)
LOG_LEVEL=INFO

# ===== OPTIONNEL: Mail (si utilisation) =====
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your_email@gmail.com
# MAIL_PASSWORD=your_password

ROOT_PATH=./frida-storage
GOOGLE_APPLICATION_CREDENTIALS=./dummy-google-credentials.json

# ===== PARALLELISME OCR =====
# Nombre de dossiers (Frida) pouvant être traités simultanément.
# Le service OCR tourne en natif (jamais dans Docker).
MAX_PARALLEL_FOLDERS=2

WINDOWS_HOST_IP=172.26.224.1

# ===== SAUVEGARDE & ARCHIVAGE =====
# Activer les sauvegardes/archivages automatiques (true/false)
BACKUP_AUTO_ENABLED=false
# Nombre de jours de rétention des sauvegardes
BACKUP_RETENTION_DAYS=7
# Heure de la sauvegarde automatique (format cron Spring)
BACKUP_CRON=0 0 2 * * *
# Seuil d'archivage en mois (dossiers plus vieux que X mois sont archivables)
ARCHIVE_THRESHOLD_MONTHS=6
# Chemin des archives (laisser vide pour utiliser ROOT_PATH/archives)
ARCHIVE_PATH=
# Heure de l'archivage automatique (format cron, défaut: 1er du mois à 3h)
ARCHIVE_CRON=0 0 3 1 * *

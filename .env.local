# ==========================================
# FRIDA — Configuration locale
# ==========================================
# Modifiez ces valeurs si nécessaire.
# Les valeurs par défaut fonctionnent telles quelles.

# Port d'accès à Frida dans votre navigateur
# Par défaut : http://localhost (port 80)
# Si le port 80 est déjà utilisé, changez-le (ex: 8080)
PORT_WEB=80

# Base de données (ne pas modifier sauf raison spécifique)
DB_NAME=frida_db
DB_USER=frida
DB_PASSWORD=frida_local_2026

version: '3.8'

services:
  # ===== Base de données postgreSQL =====
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    ports:
      - "${DATABASE_PORT}:5432"
    volumes:
      - frida_data:/var/lib/postgresql/data
      - ./config/init-db.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - frida-network
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}" ]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # ===== Frontend Angular =====
  frontend:
    # On tire l'image précompilée au lieu de la construire
    image: mon-entreprise/frida-frontend:1.0.0
    ports:
      - "${FRONTEND_PORT}:80"
    environment:
      BACKEND_URL: http://backend:${BACKEND_PORT}
    depends_on:
      - backend
    networks:
      - frida-network
    restart: unless-stopped

  # ===== Backend Spring Boot =====
  backend:
    image: mon-entreprise/frida-backend:1.0.0
    environment:
      DB_HOST: db
      DB_PORT: 5432
      DB_NAME: ${DB_NAME}
      DB_USER: ${DB_USER}
      DB_PASSWORD: ${DB_PASSWORD}
      BACKEND_PORT: ${BACKEND_PORT}
      SPRING_PROFILES_ACTIVE: production # On force en mode production (sécurité)
      CORS_ORIGINS: ${CORS_ORIGINS}
      ROOT_PATH: /frida-storage/
      GOOGLE_APPLICATION_CREDENTIALS: /app/config/google-credentials.json
      SERVICES_CALCULS_URL: http://calculs-api:8081
      SERVICES_OCR_URL: http://ocr-api:8082
    ports:
      - "${BACKEND_PORT}:${BACKEND_PORT}"
    depends_on:
      db:
        condition: service_healthy
    networks:
      - frida-network
    volumes:
      # Seules les données variables du client sont liées, pas de code source
      - frida_uploads:/app/uploads
      - ${ROOT_PATH}:/frida-storage/
    restart: unless-stopped

  # ===== Service OCR (Python Flask) =====
  ocr-api:
    image: mon-entreprise/frida-ocr-api:1.0.0
    environment:
      PORT: 8082
      ALLOWED_ORIGINS: ${CORS_ORIGINS}
    volumes:
      - frida_uploads:/app/app_ocr/uploads
      - frida_entities:/app/app_ocr/entities
    networks:
      - frida-network
    restart: unless-stopped

  # ===== Service Calculs (Spring Boot) =====
  calculs-api:
    image: mon-entreprise/frida-calculs-api:1.0.0
    environment:
      SERVER_PORT: 8081
      CORS_ORIGINS: ${CORS_ORIGINS}
    networks:
      - frida-network
    restart: unless-stopped

networks:
  frida-network:
    driver: bridge

volumes:
  frida_data:
  frida_uploads:
  frida_entities:
